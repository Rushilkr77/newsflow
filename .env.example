# Copy to .env and fill in your values. Never commit .env.

# Anthropic API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenRouter (fallback LLM routing)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Gmail OAuth credentials (download from Google Cloud Console)
GMAIL_CREDENTIALS_PATH=credentials.json
GMAIL_TOKEN_PATH=token.json

# ElevenLabs (optional — Phase 2 TTS fallback)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Local LLM via Ollama (set to true to use local models instead of Anthropic API)
USE_LOCAL_LLM=false
LOCAL_LLM_MODEL=qwen2.5:7b       # fallback model if per-agent override is not set
LOCAL_LLM_URL=http://localhost:11434/v1

# Per-agent model selection (only used when USE_LOCAL_LLM=true)
CURATOR_LOCAL_MODEL=qwen2.5:3b       # JSON classification — best 3B model for structured output
SUMMARIZER_LOCAL_MODEL=qwen2.5:7b    # Tiered summaries — 7B for better section discipline
SCRIPT_LOCAL_MODEL=qwen2.5:7b        # Podcast script

# Newsletter sender configuration
# NEWSLETTER_SENDERS: comma-separated sender emails routed to generic parser.
NEWSLETTER_SENDERS=

# ACTIVE_SOURCES: comma-separated source IDs to override senders.yaml enabled flags.
ACTIVE_SOURCES=

# Supabase (multi-user pipeline orchestration + web app)
# Get from supabase.com → project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Google Drive (MP3 upload — separate token from Gmail)
DRIVE_TOKEN_PATH=drive_token.json

# Google Cloud TTS (Neural2 — primary TTS provider, 4M chars/mo free)
# Option A: service-account JSON (recommended for servers/launchd):
#   1. Create GCP project, enable Cloud Text-to-Speech API
#   2. Create service account → download JSON key → save at repo root
GOOGLE_APPLICATION_CREDENTIALS=gcloud-tts-sa.json
# Option B: API key (simpler for local dev):
# GOOGLE_TTS_API_KEY=your_api_key_here

# Email delivery (Resend — sends from hello@newsflow.ink, verified domain)
# Get key from resend.com → API Keys
RESEND_API_KEY=your_resend_api_key_here
# Admin recipient — gets the internal review_report.md attachment other users don't
ADMIN_EMAIL=rushilmisc77@gmail.com
